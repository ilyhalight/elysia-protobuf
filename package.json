{
  "name": "elysia-protobuf",
  "version": "2.0.0",
  "author": "Toil",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "elysia": "^1.4.29",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsc-esm-fix": "^3.1.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "elysia": ">= 1.3.0"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./error": {
      "require": "./dist/error.js",
      "import": "./dist/error.js",
      "types": "./dist/error.d.ts"
    },
    "./sign": {
      "require": "./dist/sign.js",
      "import": "./dist/sign.js",
      "types": "./dist/sign.d.ts"
    },
    "./type-system": {
      "require": "./dist/type-system.js",
      "import": "./dist/type-system.js",
      "types": "./dist/type-system.d.ts"
    },
    "./types/*": {
      "require": "./dist/types/*.js",
      "import": "./dist/types/*.js",
      "types": "./dist/types/*.d.ts"
    }
  },
  "bugs": {
    "url": "https://github.com/ilyhalight/elysia-protobuf/issues"
  },
  "description": "Easy support protobuf integration for Elysia. To decode/encode we use @bufbuild/protobuf lib and schemas generated by ts-proto",
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/ilyhalight/elysia-protobuf",
  "keywords": [
    "elysia",
    "bun",
    "proto",
    "protobuf",
    "encode",
    "decode",
    "binary",
    "buf"
  ],
  "license": "MIT",
  "scripts": {
    "build:bun": "bun run ./scripts/build.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "bunx oxlint",
    "lint:fix": "bunx oxlint --fix"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
